<script type="text/javascript">
$(document).ready(function(){
	// Deshabilitamos botones
	$('#btnUserDelete').addClass('disabled');
	$('#btnUserSave').addClass('disabled');
	$('#btnUserCancel').addClass('disabled');
	$('#btnUserAdd').tooltip();
	$('#btnUserDelete').tooltip();
	$('#btnUserSave').tooltip();
	$('#btnUserCancel').tooltip();
	$('a').tooltip();
	// Roles
	/*
	$("#roles").click(function(){
		$("#roles").each(function(){
			$(this).find("a").css({
				'background-color' : '#fff',
			    'font-weight' : 'normal',
				'color' : '#0088cc'
			});
		});
		$(this).find('a').css({
			'background-color' : '#ddd',
		    'font-weight' : 'bold',
			'color' : 'rgb(0,40,244)'
		});
	});
	*/
	// Empresas
	/*
	$("div#empresas > dl > dt").click(function(){
		var cheke =  $(this).find('input[type="checkbox"]').is(':checked');
		$(this).parent().find('dd').each(function(){
			$(this).find('input[type="checkbox"]').attr('checked', cheke);
		});
	});
	*/
	// Validacion de Formulario de Adicion de Usuario a Rol
	var aform = $("#frmAddUser2Rol").validate({
		rules: {
			usr_usuario: {
				required: true
			},
			usr_nombre:{
				required: true
			},
	     	usr_password: {
	       		required: true
	     	},
		    usr_password2: {
			    required: true,
			    equalTo: "#usr_password"
		    },
		    id_rol: {
			    required: true
		    }
	   },
	   messages: {
	     	usr_usuario: {
		     	required : "Digite usuario"
	     	},
			usr_nombre: {
				required: "Digite nombre"
			},
	     	usr_password: {
	       		required: "Digite contrase�a"
	     	},
	     	usr_password2: {
		     	required: "Digite contrase�a",
		     	equalTo: "Contrase�as no son iguales"
	     	},
	     	id_rol: {
		     	required: "Seleccion Rol"
	     	}
		},
		submitHandler: function(form) {
		    var campos=xajax.getFormValues("frmAddUser2Rol");
			$('#waiting').show().dialog({
				modal: true,
				width: 250,
				height: 100
			});
			$(":submit").prop("disabled", true);
			myUrlOC = location.protocol + "//" + location.host + '/sicys/json.php?c=usua&a=verifica';
			$.post(myUrlOC, 
				{ 
					form: campos
				}, 
				function(json) {
					if(json == "OK"){
						myUrl = location.protocol + "//" + location.host + "/sicys/class/Formulario.php";
						$.ajax({
							type : "POST",
							url : myUrl,
							data: {
								form: campos
							},
							beforeSend: function(){
								$("input[type=submit]").attr("disabled","disabled");
							},
							success : function(data){
							    $('#waiting').dialog('close');
								if(data == "OK" ){
									location.reload();
								} else {
									showNotification({
										type : "error",
								        message: "Adicionando Usuario :" + data,
								        autoClose: true,
								        duration: 4
									});
								}
							},
							error : function(XMLHttpRequest, textStatus, errorThrown) {
							    $('#waiting').dialog('close');
							    showNotification({
									type : "error",
							        message: "Formulario : Ha ocurrido un error durante la ejecucion.",
							        autoClose: true,
							        duration: 2
								});
							}
						});
					} else {
						showNotification({
							type : "error",
					        message: 'Verificando Usuario :' + json,
					        autoClose: true,
					        duration: 4
						});
						$(":submit").prop("disabled", false);
						$('#waiting').dialog('close');
					} 
			 	}
			);
	     }
	}); 
	// our modal dialog setup
	var amodal = $("#formAdicion").dialog({
	   bgiframe: true,
	   autoOpen: false,
       resizable: false,
       modal: true,
       width: 600,
	   buttons: {
	      'Agregar': function() 
		  { 
		  	$("#frmAddUser2Rol").submit(); 
		  },
	      Cancel: function() 
		  { 
		    $(this).dialog('close'); aform.resetForm(); 
		  }
	   }
	});
	var abutton = $('#btnUserAdd').click(function() {
	    $('#formAdicion').dialog('open');
	});
	// DYNATREE
	alto_doc = ($(document).height()-100);
	alto_span4 = (alto_doc / 2);
	ancho = $('.span4').width();
	$('.span4.table-bordered').css({
		'height' : alto_span4
	});
	$("#jqxTree").dynatree({
			checkbox: true,
			selectMode: 3,
			fx: { height: "toggle", duration: 200 }, 
			autoCollapse: true,
			onKeydown: function(node, event) {
				if( event.which == 32 ) {
					node.toggleSelect();
					return false;
				}
			}
      });
});
</script>

